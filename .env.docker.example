# ------------------------------------------------------------------
# Docker Compose environment template
# Copy to .env.docker and fill in every value before: docker compose up
# ------------------------------------------------------------------

# ------------------------------------------------------------------
# Auth.js (NextAuth v5) - generate via: openssl rand -base64 32
# ------------------------------------------------------------------
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Required in Docker/production (NODE_ENV=production disables implicit trustHost in auth.config.ts)
AUTH_TRUST_HOST=true

# ------------------------------------------------------------------
# Google / Gmail OAuth
# ------------------------------------------------------------------
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ------------------------------------------------------------------
# Microsoft / Outlook OAuth
# ------------------------------------------------------------------
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# ------------------------------------------------------------------
# Database (choose one mode)
#
# Cloud Supabase (recommended — full Realtime + AI):
#   DATABASE_URL = transaction pooler (port 6543) + ?pgbouncer=true
#   DIRECT_URL   = session pooler (port 5432)
#
# Local Postgres (--profile local-db):
#   DATABASE_URL=postgresql://vigil:vigil@postgres:5432/vigil?sslmode=disable
#   DIRECT_URL=postgresql://vigil:vigil@postgres:5432/vigil?sslmode=disable
#   WAIT_FOR_DB=true
#   APPLY_PG_STUB=true
# ------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=
WAIT_FOR_DB=false
APPLY_PG_STUB=false
RUN_MIGRATIONS=true

# ------------------------------------------------------------------
# Supabase project API (required for Realtime, analysis queue, FastAPI worker)
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# FastAPI uses the same project via service role (server only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared webhook secret (Next.js INTERNAL_AI_SECRET = FastAPI INTERNAL_AI_SECRET)
INTERNAL_AI_SECRET=

# ------------------------------------------------------------------
# FastAPI runtime (api service only — do not use PORT for the web container)
# ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
ENABLE_WORKER=true
QUEUE_MAXSIZE=1000
ANALYSIS_REQUEST_POLL_INTERVAL_SEC=2.0
ANALYSIS_REQUEST_BATCH_SIZE=25
ANALYSIS_ALL_UNANALYZED_LIMIT=200
QUEUE_BACKPRESSURE_HIGH_WATERMARK=800
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
INTENT_MATCH_LIMIT=5

# LLM provider: groq | ollama | openai_compatible
# Use groq (default) with GROQ_API_KEY, or --profile ollama with settings below.
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Optional: web grounding
WEB_GROUNDING_ENABLED=false
TAVILY_API_KEY=
RAG_DEBUG_LOGS=false
