# FastAPI (backend only — copy to .env and adjust)
HOST=127.0.0.1
PORT=8000
# Comma-separated, no spaces (or spaces OK — trimmed)
CORS_ORIGINS=http://localhost:3000
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GROQ_API_KEY=
LLM_PROVIDER=ollama
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_BASE_URL=
OPENAI_API_KEY=
INTERNAL_AI_SECRET=
QUEUE_MAXSIZE=1000
ENABLE_WORKER=true
ANALYSIS_REQUEST_POLL_INTERVAL_SEC=2.0
ANALYSIS_REQUEST_BATCH_SIZE=25
ANALYSIS_ALL_UNANALYZED_LIMIT=200
QUEUE_BACKPRESSURE_HIGH_WATERMARK=800
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
INTENT_MATCH_LIMIT=5
GROQ_MODEL=llama-3.1-8b-instant

# Optional: web grounding (privacy-aware; disabled by default)
WEB_GROUNDING_ENABLED=false
# Used only when WEB_GROUNDING_ENABLED=true
TAVILY_API_KEY=

# Optional: debug evidence logs for RAG/grounding
RAG_DEBUG_LOGS=false
