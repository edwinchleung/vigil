# ------------------------------------------------------------------
# Auth.js (NextAuth v5) - generate a secret via: openssl rand -base64 32
# ------------------------------------------------------------------
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ------------------------------------------------------------------
# Google / Gmail OAuth (from Google Cloud Console)
# ------------------------------------------------------------------
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ------------------------------------------------------------------
# Microsoft / Outlook OAuth (from Azure Portal - Microsoft Entra ID)
# Keep "common" as the issuer tenant unless you are locking the app
# to a single Azure tenant.
# ------------------------------------------------------------------
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# ------------------------------------------------------------------
# Supabase Postgres (Settings -> Database -> Connection string)
# DATABASE_URL = Supavisor transaction mode (port 6543) + ?pgbouncer=true for Prisma
# DIRECT_URL   = Supavisor session mode (pooler host, port 5432) for Prisma migrations.
#                Use this if db.*.supabase.co:5432 is unreachable (IPv4-only networks; direct is IPv6 by default).
# ------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

# ------------------------------------------------------------------
# Supabase project (Settings -> API) — browser client + Realtime; anon key is safe in NEXT_PUBLIC_*
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only: same project JWT secret (Settings -> API -> JWT secret) to sign short-lived
# user tokens for RLS/Realtime. Never commit or prefix with NEXT_PUBLIC_.
SUPABASE_JWT_SECRET=

# ------------------------------------------------------------------
# Shared secret: verify Supabase / Edge → FastAPI webhooks (HMAC, Bearer, etc.). Optional mirror in SystemConfig.
# ------------------------------------------------------------------
# This same value must be set in the FastAPI backend env (`backend/.env`) as `INTERNAL_AI_SECRET`.
INTERNAL_AI_SECRET=

# ------------------------------------------------------------------
# Inbox sync: per-user cooldown + mutex (prevents API/DB abuse). Timeouts in seconds.
# ------------------------------------------------------------------
# Min seconds between starting syncs for the same user (default 60).
# SYNC_MIN_INTERVAL_SEC=60
# How long a sync lease is held if the server never releases the lock (crash recovery, default 600).
# SYNC_LOCK_TTL_SEC=600
# Fallback Retry-After hint when a busy state cannot be resolved from DB (default 10).
# SYNC_LOCK_BUSY_RETRY_SEC=10